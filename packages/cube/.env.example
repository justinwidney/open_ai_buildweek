# Copy to .env and point at a real Postgres instance holding @control-ai/db's schema.
# (PGlite, the zero-install local/test DB, has no wire port for cube to connect to —
#  see cube.js and README.md.)

CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=localhost
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=control_ai
CUBEJS_DB_USER=postgres
CUBEJS_DB_PASS=postgres

# Dev-only API secret for the local Cube server and Playground.
CUBEJS_DEV_MODE=true
CUBEJS_API_SECRET=dev-secret-change-me
