{
  "name": "@control-ai/db",
  "version": "0.1.0",
  "private": true,
  "description": "Postgres-first Drizzle schema, migrations, and repository layer for simulation runs.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@control-ai/engine": "workspace:*",
    "@control-ai/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
